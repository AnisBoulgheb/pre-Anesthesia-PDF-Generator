{
  "name": "pdf-generator",
  "version": "1.0.0",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output CPA-Generator.exe"
  },
  "author": "Anis BOULGHEB",
  "license": "ISC",
  "description": "Offline PDF Generator for Consultation Pré-Anesthésique",
  "dependencies": {
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "ignore": [
      "nodemon"
    ]
  }
}